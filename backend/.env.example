# Server Configuration
PORT=3001
NODE_ENV=development

# Frontend URL (for redirects)
FRONTEND_URL=http://localhost

# ========================================
# SUPABASE CONFIGURATION
# ========================================
# Get these from your Supabase project:
# 1. Go to https://supabase.com/dashboard
# 2. Select your project
# 3. Go to Settings (gear icon) → API
# 4. Copy the URL and anon/public key

SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# ========================================
# AUTH CONFIGURATION
# ========================================
# JWT settings (Supabase handles this, but kept for compatibility)
JWT_SECRET=your-jwt-secret
JWT_EXPIRES_IN=1d

# ========================================
# EMAIL CONFIGURATION (Optional)
# ========================================
# For password reset emails
# SMTP settings for nodemailer
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# ========================================
# OAUTH CONFIGURATION (Optional)
# ========================================
# If you want to enable Google/Facebook login via Supabase instead
# Configure in Supabase Dashboard: Authentication → Providers
# No need to configure here - Supabase handles OAuth!

# ========================================
# GOOGLE BOOKS API
# ========================================
# Get your API key from Google Cloud Console:
# 1. Go to https://console.cloud.google.com/
# 2. Create or select a project
# 3. Enable "Books API" in APIs & Services
# 4. Go to Credentials → Create Credentials → API Key
# 5. (Optional) Restrict the key to Books API only
GOOGLE_BOOKS_API_KEY=your-google-books-api-key
